<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="Sunder.App.Views.Controls.WindowChromeControls"
             mc:Ignorable="d">
  <StackPanel Orientation="Horizontal"
              Spacing="8"
              VerticalAlignment="Center">
    <Button Classes="window-action-button"
            Click="MinimizeButton_OnClick">
      <Path Width="12"
            Height="12"
            Classes="icon-stroke"
            Data="{StaticResource Sunder.Icon.Minimize}" />
    </Button>
    <Button Classes="window-action-button"
            Click="ToggleFullScreenButton_OnClick">
      <Path Width="12"
            Height="12"
            Classes="icon-stroke"
            Data="{StaticResource Sunder.Icon.Maximize}" />
    </Button>
    <Button Classes="window-action-button close-button"
            Click="CloseButton_OnClick">
      <Path Width="12"
            Height="12"
            Classes="icon-stroke"
            Data="{StaticResource Sunder.Icon.Close}" />
    </Button>
  </StackPanel>
</UserControl>
