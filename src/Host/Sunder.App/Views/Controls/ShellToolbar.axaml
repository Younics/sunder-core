<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Sunder.App.ViewModels"
             xmlns:controls="using:Sunder.App.Views.Controls"
             x:Class="Sunder.App.Views.Controls.ShellToolbar"
             x:DataType="vm:MainWindowViewModel"
             mc:Ignorable="d">
  <controls:WindowTitleBar IsLogoLarge="True">
    <controls:WindowTitleBar.LeadingContent>
      <StackPanel x:Name="ToolbarLeftMenuHost"
                  Orientation="Horizontal"
                  Spacing="14"
                  Height="40"
                  VerticalAlignment="Center">
        <Grid x:Name="ToolbarLeftActionHost"
              Height="40"
              VerticalAlignment="Center">
          <StackPanel x:Name="ToolbarDefaultActions"
                      Orientation="Horizontal"
                      Spacing="14"
                      Height="40"
                      VerticalAlignment="Center">
            <Button Classes="toolbar-icon"
                    Command="{Binding OpenPackagesCommand}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Packages">
              <Path Width="15"
                    Height="15"
                    Classes="icon-stroke"
                    Data="{StaticResource Sunder.Icon.Packages}" />
            </Button>

            <Button Classes="toolbar-icon"
                    Command="{Binding OpenSettingsCommand}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Settings">
              <Path Width="16"
                    Height="16"
                    Classes="icon-stroke"
                    Data="{StaticResource Sunder.Icon.Settings}" />
            </Button>

            <Button x:Name="MoreActionsButton"
                    Classes="toolbar-icon"
                    VerticalAlignment="Center"
                    ToolTip.Tip="View and package actions"
                    Click="MoreActionsButton_OnClick">
              <Grid Width="16"
                    Height="16"
                    ColumnDefinitions="*,*,*"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Ellipse Grid.Column="0"
                         Width="3"
                         Height="3"
                         Classes="toolbar-dot"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                <Ellipse Grid.Column="1"
                         Width="3"
                         Height="3"
                         Classes="toolbar-dot"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                <Ellipse Grid.Column="2"
                         Width="3"
                         Height="3"
                         Classes="toolbar-dot"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
              </Grid>
            </Button>
          </StackPanel>

          <Menu x:Name="ToolbarMainMenu"
                Classes="toolbar-main-menu"
                IsVisible="False"
                Height="40"
                VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </controls:WindowTitleBar.LeadingContent>

    <controls:WindowTitleBar.CenterContent>
      <controls:PackageIconBar x:Name="MiddlePackageIconBar"
                               Width="548"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               DataContext="{Binding MiddleBar}" />
    </controls:WindowTitleBar.CenterContent>

    <controls:WindowTitleBar.TrailingContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">
        <controls:RuntimeStatusButton />
        <controls:NotificationToolbarButton />
      </StackPanel>
    </controls:WindowTitleBar.TrailingContent>
  </controls:WindowTitleBar>
</UserControl>
