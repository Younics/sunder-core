<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Sunder.App.ViewModels"
        xmlns:controls="using:Sunder.App.Views.Controls"
        x:Class="Sunder.App.Views.PackagesWindow"
        x:DataType="vm:PackagesWindowViewModel"
        mc:Ignorable="d"
        Width="1200"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Packages"
        Icon="avares://Sunder.App/Assets/Images/app.ico"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        Classes="secondary-window">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Window.Styles>
    <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml" />
  </Window.Styles>

  <Grid RowDefinitions="52,*,Auto"
        Background="{DynamicResource Sunder.Brush.Background.App}">
    <Border Grid.Row="0"
            x:Name="ToolbarDragHost"
            PointerPressed="ToolbarDragHost_OnPointerPressed"
            Classes="toolbar-surface">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
            ColumnSpacing="12"
            VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <Border Classes="toolbar-logo-badge">
            <Image Source="avares://Sunder.App/Assets/Images/icon.png"
                   RenderOptions.BitmapInterpolationMode="HighQuality"
                   Stretch="Uniform" />
          </Border>
          <TextBlock Classes="section-title"
                     VerticalAlignment="Center"
                     Text="Packages" />
        </StackPanel>

        <Border Grid.Column="1"
                Classes="search-host"
                MaxWidth="480"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsMarketplaceMode}">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="10"
                VerticalAlignment="Center">
            <TextBlock Classes="caption"
                       Text="Registry"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Classes="search-box"
                     Text="{Binding RegistryUrlText}"
                     PlaceholderText="https://hub.sunderapp.io/" />
          </Grid>
        </Border>

        <Button Grid.Column="2"
                Classes="toolbar-icon"
                Command="{Binding RefreshCommand}"
                VerticalAlignment="Center"
                ToolTip.Tip="Refresh packages"
                IsEnabled="{Binding CanRefresh}">
          <Path Width="15"
                Height="15"
                Classes="icon-stroke"
                Data="{StaticResource Sunder.Icon.Refresh}" />
        </Button>

        <Border Grid.Column="3"
                Width="1"
                Height="24"
                Margin="4,0"
                Background="{DynamicResource Sunder.Brush.Border.Subtle}" />

        <controls:WindowChromeControls Grid.Column="4" />
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Margin="20,12,20,0"
            Classes="panel-surface"
            Padding="0">
      <Border Classes="secondary-panel-content-clip">
        <Grid x:Name="PackagesContentGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="430" MinWidth="240" MaxWidth="900" />
          <ColumnDefinition Width="4" />
          <ColumnDefinition Width="*" MinWidth="420" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                x:Name="PackagesListPane"
                Background="{DynamicResource Sunder.Brush.Surface.Base}"
                Padding="16">
          <Grid RowDefinitions="Auto,Auto,*"
                RowSpacing="12">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Classes="secondary-action settings-nav-button"
                      Classes.selected="{Binding IsMarketplaceMode}"
                      Command="{Binding ShowMarketplaceCommand}"
                      Content="Marketplace" />
              <Button Classes="secondary-action settings-nav-button"
                      Classes.selected="{Binding IsInstalledMode}"
                      Command="{Binding ShowInstalledCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Installed" />
                  <Border Classes="notification-unread-pill"
                          IsVisible="{Binding ShowUpdateAllPackages}">
                    <TextBlock Text="{Binding AvailableUpdateCount}" />
                  </Border>
                </StackPanel>
              </Button>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="search-host">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="8"
                    VerticalAlignment="Center">
                <TextBox Classes="search-box"
                         Text="{Binding SearchText}"
                         PlaceholderText="{Binding SearchPlaceholder}" />
                <Button Grid.Column="1"
                        Classes="search-clear-button"
                        Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding HasSearchText}"
                        ToolTip.Tip="Clear search">
                  <Path Width="10"
                        Height="10"
                        Classes="icon-stroke"
                        Data="{StaticResource Sunder.Icon.Close}" />
                </Button>
              </Grid>
            </Border>

            <Grid Grid.Row="2">
              <ListBox Classes="package-list"
                       ItemsSource="{Binding MarketplacePackages}"
                       SelectedItem="{Binding SelectedMarketplacePackage, Mode=TwoWay}"
                       IsVisible="{Binding IsMarketplaceMode}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:RegistryPackageSearchItemViewModel">
                    <controls:PackageListRow IsSelected="{Binding IsSelected}"
                                             IconImage="{Binding IconImage}"
                                             HasIconImage="{Binding HasIconImage}"
                                             Glyph="{Binding Glyph}"
                                             ShowGlyphFallback="{Binding ShowGlyphFallback}"
                                             Title="{Binding Name}"
                                              PackageId="{Binding PackageId}"
                                              PrimaryBadge="{Binding LatestVersionText}"
                                              DetailBadge="{Binding InstalledVersionText}"
                                              ShowDetailBadge="{Binding IsInstalled}"
                                              ActionBadge="{Binding ActionText}"
                                              ShowBadgeRow="{Binding ShowRowBadges}"
                                              ShowActionBadge="{Binding HasUpdate}"
                                              ActionBadgeIsUpdate="{Binding HasUpdate}"
                                              OperationStatusText="{Binding OperationStatusText}"
                                             ShowOperationStatus="{Binding ShowOperationStatus}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <ListBox Classes="package-list"
                       ItemsSource="{Binding InstalledPackages}"
                       SelectedItem="{Binding SelectedInstalledPackage, Mode=TwoWay}"
                       IsVisible="{Binding IsInstalledMode}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:PackageCatalogItemViewModel">
                    <controls:PackageListRow IsSelected="{Binding IsSelected}"
                                             IconImage="{Binding IconImage}"
                                             HasIconImage="{Binding HasIconImage}"
                                             Glyph="{Binding Glyph}"
                                             ShowGlyphFallback="{Binding ShowGlyphFallback}"
                                             Title="{Binding DisplayName}"
                                             PackageId="{Binding PackageId}"
                                             PrimaryBadge="{Binding StatusText}"
                                             DetailBadge="{Binding SourceLabel}"
                                             ActionBadge="{Binding UpdateText}"
                                             ShowActionBadge="{Binding HasUpdate}"
                                             ActionBadgeIsUpdate="True"
                                             OperationStatusText="{Binding OperationStatusText}"
                                             ShowOperationStatus="{Binding ShowOperationStatus}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <TextBlock Classes="muted"
                         IsVisible="{Binding ShowNoMarketplacePackages}"
                         Text="No marketplace packages loaded. Use refresh to search the configured registry."
                         TextWrapping="Wrap" />

              <TextBlock Classes="muted"
                         IsVisible="{Binding ShowNoInstalledPackages}"
                         Text="No packages are installed or active in the current session."
                         TextWrapping="Wrap" />
            </Grid>
          </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="4"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False"
                      Background="{DynamicResource Sunder.Brush.Border.Subtle}"
                      DragCompleted="PackagesSplitter_OnDragCompleted" />

        <Border Grid.Column="2"
                Classes="workspace-surface"
                Margin="16">
          <ScrollViewer>
            <StackPanel Margin="18"
                        Spacing="16">
              <controls:PackageDetailsHeader />

              <controls:MarketplacePackageDetails IsVisible="{Binding ShowMarketplaceDetails}" />

              <controls:InstalledPackageDetails IsVisible="{Binding ShowInstalledDetails}" />

              <controls:PackageWarningsPanel IsVisible="{Binding HasWarnings}" />

              <TextBlock Classes="muted"
                         IsVisible="{Binding ShowNoSelection}"
                         Text="Select a package from the list to inspect details and actions."
                         TextWrapping="Wrap" />
            </StackPanel>
          </ScrollViewer>
        </Border>
        </Grid>
      </Border>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="Auto,*,Auto,Auto"
          Margin="20,16,20,16"
          ColumnSpacing="16">
      <Button Classes="secondary-action"
              Command="{Binding InstallPackageCommand}"
              Content="Install from disk"
              IsEnabled="{Binding CanInstallPackage}" />

      <Button Grid.Column="2"
              Classes="primary-action"
              Command="{Binding UpdateAllPackagesCommand}"
              Content="Update All"
              IsEnabled="{Binding CanUpdateAllPackages}"
              IsVisible="{Binding ShowUpdateAllPackages}" />
      <controls:BackgroundProcessMonitor Grid.Column="3"
                                         HorizontalAlignment="Right"
                                         DataContext="{Binding PackageProcesses}" />
    </Grid>
  </Grid>
</Window>
