<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window.shell-window, Window.secondary-window, Window.loading-window">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Background.App}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Border.toolbar-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Workspace}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="8,7" />
  </Style>

  <Style Selector="Border.toolbar-logo-badge">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="3" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.toolbar-logo-badge.large">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="CornerRadius" Value="9" />
  </Style>

  <Style Selector="Path.icon-stroke">
    <Setter Property="Fill" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="Stroke" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="StrokeLineCap" Value="Round" />
    <Setter Property="StrokeThickness" Value="1.45" />
  </Style>

  <Style Selector="Path.icon-fill">
    <Setter Property="Fill" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="Stretch" Value="Uniform" />
  </Style>

  <Style Selector="Ellipse.toolbar-dot">
    <Setter Property="Fill" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
  </Style>

  <Style Selector="Button.toolbar-icon:pointerover Path.icon-stroke, Button.window-action-button:pointerover Path.icon-stroke, Button.search-clear-button:pointerover Path.icon-stroke, Button.toast-close-button:pointerover Path.icon-stroke, Button.update-prompt-close-button:pointerover Path.icon-stroke">
    <Setter Property="Stroke" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.toolbar-icon:pointerover Path.icon-fill, Button.window-action-button:pointerover Path.icon-fill, Button.search-clear-button:pointerover Path.icon-fill, Button.rail-button:pointerover Path.icon-fill">
    <Setter Property="Fill" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.toolbar-icon:pointerover Ellipse.toolbar-dot">
    <Setter Property="Fill" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.close-button:pointerover Path.icon-stroke">
    <Setter Property="Stroke" Value="{DynamicResource Sunder.Brush.Foreground.OnDanger}" />
  </Style>

  <Style Selector="Border.panel-header-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
  </Style>

  <Style Selector="Border.search-host">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Workspace}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="36" />
  </Style>

  <Style Selector="Border.search-shortcut-chip">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="22" />
  </Style>

  <Style Selector="TextBlock.search-icon">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.search-clear-button">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.search-clear-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Border.rail-surface, Border.side-rail-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Background.App}" />
  </Style>

  <Style Selector="Border.workspace-shell-panel">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="BoxShadow" Value="{DynamicResource Sunder.Shadow.WorkspacePanel}" />
  </Style>

  <Style Selector="Border.side-shell-panel, Border.bottom-shell-panel">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="BoxShadow" Value="{DynamicResource Sunder.Shadow.ShellPanel}" />
  </Style>

  <Style Selector="Border.shell-panel-content-clip, Border.secondary-panel-content-clip">
    <Setter Property="Margin" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="FlyoutPresenter.runtime-flyout-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.update-prompt-card">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="Padding" Value="18" />
    <Setter Property="BoxShadow" Value="{DynamicResource Sunder.Shadow.Prompt}" />
  </Style>

  <Style Selector="Border.update-prompt-icon">
    <Setter Property="Width" Value="26" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style Selector="Border.update-prompt-icon TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="FontSize" Value="18" />
  </Style>

  <Style Selector="TextBlock.update-prompt-title">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.update-prompt-close-button">
    <Setter Property="Width" Value="26" />
    <Setter Property="Height" Value="26" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Top" />
  </Style>

  <Style Selector="Button.update-prompt-close-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.update-prompt-primary-action, Button.update-prompt-secondary-action">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.update-prompt-primary-action">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.update-prompt-secondary-action">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
  </Style>

  <Style Selector="Button.update-prompt-primary-action:pointerover, Button.update-prompt-secondary-action:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Accent}" />
  </Style>

  <Style Selector="Border.settings-note-card">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Medium}" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="Button.toolbar-icon, Button.window-action-button">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="FontSize" Value="17" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.toolbar-icon:pointerover, Button.window-action-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.mac-window-action-button">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="9" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Menu.toolbar-main-menu">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Height" Value="40" />
    <Setter Property="MinHeight" Value="40" />
  </Style>

  <Style Selector="MenuItem.toolbar-menu-root-item">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="40" />
    <Setter Property="MinHeight" Value="40" />
  </Style>

  <Style Selector="MenuItem.toolbar-menu-item">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="MinWidth" Value="180" />
  </Style>

  <Style Selector="MenuItem.toolbar-menu-item:pointerover, MenuItem.toolbar-menu-root-item:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Selected}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Border.toolbar-menu-icon-badge">
    <Setter Property="Width" Value="20" />
    <Setter Property="Height" Value="20" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBlock.toolbar-menu-icon-text">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Accent}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.close-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Danger.Soft}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.OnDanger}" />
  </Style>

  <Style Selector="Button.rail-button">
    <Setter Property="Width" Value="38" />
    <Setter Property="Height" Value="38" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
  </Style>

  <Style Selector="Button.rail-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.rail-button.selected">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Info}" />
  </Style>

  <Style Selector="Button.side-rail-button">
    <Setter Property="Width" Value="34" />
    <Setter Property="Height" Value="34" />
  </Style>

  <Style Selector="Button.bottom-tab">
    <Setter Property="Padding" Value="10,6" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.bottom-tab:pointerover">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.bottom-tab.selected">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
  </Style>

  <Style Selector="Button.panel-control-button">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
  </Style>

  <Style Selector="Button.panel-control-button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.secondary-action.settings-nav-button.selected">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Selected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="TextBlock.runtime-error-text">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Danger}" />
  </Style>

  <Style Selector="StackPanel.drag-target.drag-over">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.DragOver}" />
  </Style>

  <Style Selector="TextBox.search-box">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="CaretBrush" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource Sunder.Brush.Selection}" />
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="TextBox.search-box:focus, TextBox.search-box:focus-within, TextBox.search-box:focus-visible">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
  </Style>

  <Style Selector="TextBox.search-box /template/ Border">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBox.search-box:focus /template/ Border, TextBox.search-box:focus-within /template/ Border, TextBox.search-box:focus-visible /template/ Border">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Transparent}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBlock.glyph-text">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.panel-header-text">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="TextAlignment" Value="Left" />
  </Style>

  <Style Selector="TextBlock.workspace-state-text">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="LetterSpacing" Value="0.5" />
  </Style>

  <Style Selector="Border.welcome-card">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="MaxWidth" Value="720" />
    <Setter Property="Padding" Value="42" />
  </Style>

  <Style Selector="Border.welcome-logo-frame">
    <Setter Property="Width" Value="82" />
    <Setter Property="Height" Value="82" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="Padding" Value="7" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BoxShadow" Value="{DynamicResource Sunder.Shadow.WelcomeLogo}" />
  </Style>

  <Style Selector="TextBlock.welcome-eyebrow">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Accent}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="3" />
  </Style>

  <Style Selector="TextBlock.welcome-title">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="FontSize" Value="42" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.welcome-subtitle">
    <Setter Property="MaxWidth" Value="560" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.statusbar-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Background.App}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
  </Style>

  <Style Selector="TextBlock.status-text">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>
</Styles>
