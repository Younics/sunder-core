{
  "$schema": "http://json.schemastore.org/template",
  "author": "Sunder",
  "classifications": ["Sunder", "Package", "Avalonia"],
  "identity": "Sunder.Package",
  "name": "Sunder Package",
  "shortName": "sunder-package",
  "sourceName": "Sunder.Package.Template",
  "preferNameDirectory": true,
  "symbols": {
    "packageId": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": true,
      "description": "The runtime package id written into generated package metadata.",
      "replaces": "sunder.package.template"
    },
    "packageName": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": true,
      "description": "The package name shown in Sunder.",
      "replaces": "Sunder Package Template"
    },
    "withContracts": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": false,
      "description": "Generate a sibling *.Contracts project for public extension points."
    },
    "withHostDependency": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": false,
      "description": "Scaffold package dependency metadata and integration notes for extending another package."
    },
    "withHostContracts": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": false,
      "description": "Add a PackageReference to the host package's published *.Contracts package, host dependency metadata, and a compile-safe extension stub."
    },
    "hostPackageId": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": "withHostDependency || withHostContracts == true",
      "isEnabled": "withHostDependency || withHostContracts == true",
      "description": "The package id of the host package this package extends.",
      "replaces": "sunder.host.package"
    },
    "hostContractsPackageId": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": "withHostContracts == true",
      "isEnabled": "withHostContracts == true",
      "description": "The NuGet package id of the host package's published contracts package.",
      "replaces": "Sunder.Host.Package.Contracts"
    },
    "hostContractsVersion": {
      "type": "parameter",
      "datatype": "text",
      "isRequired": "withHostContracts == true",
      "isEnabled": "withHostContracts == true",
      "description": "The version of the host package's published contracts package.",
      "replaces": "1.0.0-HOST-CONTRACTS"
    },
    "createInPlace": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": false,
      "description": "Create the package project directly in the specified output folder instead of a child project folder."
    },
    "noDefaultView": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": false,
      "description": "Generate no default shell-visible package view."
    }
  },
  "primaryOutputs": [
    {
      "condition": "(!createInPlace)",
      "path": "Sunder.Package.Template/Sunder.Package.Template.csproj"
    },
    {
      "condition": "(createInPlace)",
      "path": "Sunder.Package.Template.csproj"
    }
  ],
  "sources": [
    {
      "condition": "(!createInPlace)",
      "modifiers": [
        {
          "condition": "(!withContracts)",
          "exclude": [
            "Sunder.Package.Template.Contracts/**/*"
          ]
        },
        {
          "condition": "(!withHostDependency && withHostContracts != true)",
          "exclude": [
            "Sunder.Package.Template/Extensions/**/*",
            "Sunder.Package.Template/PackageMetadata.host.cs"
          ],
          "rename": {
            "Sunder.Package.Template/PackageMetadata.no-host.cs": "Sunder.Package.Template/PackageMetadata.cs"
          }
        },
        {
          "condition": "(withHostDependency || withHostContracts == true)",
          "exclude": [
            "Sunder.Package.Template/PackageMetadata.no-host.cs"
          ],
          "rename": {
            "Sunder.Package.Template/PackageMetadata.host.cs": "Sunder.Package.Template/PackageMetadata.cs"
          }
        },
        {
          "condition": "(withHostContracts != true)",
          "exclude": [
            "Sunder.Package.Template/Sunder.Package.Template.with-host-contracts.csproj",
            "Sunder.Package.Template/HostContracts.PackageReferences.props",
            "Sunder.Package.Template/Extensions/HostContractContributionStub.cs"
          ]
        },
        {
          "condition": "(withHostContracts == true)",
          "exclude": [
            "Sunder.Package.Template/Sunder.Package.Template.csproj"
          ],
          "rename": {
            "Sunder.Package.Template/Sunder.Package.Template.with-host-contracts.csproj": "Sunder.Package.Template/Sunder.Package.Template.csproj"
          }
        },
        {
          "condition": "(noDefaultView && !withHostDependency && withHostContracts != true)",
          "exclude": [
            "Sunder.Package.Template/PackageViews/**/*",
            "Sunder.Package.Template/PackageModule.with-view.cs"
          ],
          "rename": {
            "Sunder.Package.Template/PackageModule.no-view.cs": "Sunder.Package.Template/PackageModule.cs"
          }
        },
        {
          "condition": "(!noDefaultView && !withHostDependency && withHostContracts != true)",
          "exclude": [
            "Sunder.Package.Template/PackageModule.no-view.cs"
          ],
          "rename": {
            "Sunder.Package.Template/PackageModule.with-view.cs": "Sunder.Package.Template/PackageModule.cs"
          }
        },
        {
          "condition": "(noDefaultView && (withHostDependency || withHostContracts == true))",
          "exclude": [
            "Sunder.Package.Template/PackageViews/**/*",
            "Sunder.Package.Template/PackageModule.with-view.cs"
          ],
          "rename": {
            "Sunder.Package.Template/PackageModule.no-view.cs": "Sunder.Package.Template/PackageModule.cs"
          }
        },
        {
          "condition": "(!noDefaultView && (withHostDependency || withHostContracts == true))",
          "exclude": [
            "Sunder.Package.Template/PackageModule.no-view.cs"
          ],
          "rename": {
            "Sunder.Package.Template/PackageModule.with-view.cs": "Sunder.Package.Template/PackageModule.cs"
          }
        }
      ]
    },
    {
      "condition": "(createInPlace)",
      "source": "Sunder.Package.Template/",
      "target": "./",
      "modifiers": [
        {
          "condition": "(!withHostDependency && withHostContracts != true)",
          "exclude": [
            "Extensions/**/*",
            "PackageMetadata.host.cs"
          ],
          "rename": {
            "PackageMetadata.no-host.cs": "PackageMetadata.cs"
          }
        },
        {
          "condition": "(withHostDependency || withHostContracts == true)",
          "exclude": [
            "PackageMetadata.no-host.cs"
          ],
          "rename": {
            "PackageMetadata.host.cs": "PackageMetadata.cs"
          }
        },
        {
          "condition": "(withHostContracts != true)",
          "exclude": [
            "Sunder.Package.Template.with-host-contracts.csproj",
            "HostContracts.PackageReferences.props",
            "Extensions/HostContractContributionStub.cs"
          ]
        },
        {
          "condition": "(withHostContracts == true)",
          "exclude": [
            "Sunder.Package.Template.csproj"
          ],
          "rename": {
            "Sunder.Package.Template.with-host-contracts.csproj": "Sunder.Package.Template.csproj"
          }
        },
        {
          "condition": "(noDefaultView && !withHostDependency && withHostContracts != true)",
          "exclude": [
            "PackageViews/**/*",
            "PackageModule.with-view.cs"
          ],
          "rename": {
            "PackageModule.no-view.cs": "PackageModule.cs"
          }
        },
        {
          "condition": "(!noDefaultView && !withHostDependency && withHostContracts != true)",
          "exclude": [
            "PackageModule.no-view.cs"
          ],
          "rename": {
            "PackageModule.with-view.cs": "PackageModule.cs"
          }
        },
        {
          "condition": "(noDefaultView && (withHostDependency || withHostContracts == true))",
          "exclude": [
            "PackageViews/**/*",
            "PackageModule.with-view.cs"
          ],
          "rename": {
            "PackageModule.no-view.cs": "PackageModule.cs"
          }
        },
        {
          "condition": "(!noDefaultView && (withHostDependency || withHostContracts == true))",
          "exclude": [
            "PackageModule.no-view.cs"
          ],
          "rename": {
            "PackageModule.with-view.cs": "PackageModule.cs"
          }
        }
      ]
    },
    {
      "condition": "(createInPlace && withContracts)",
      "include": [
        "Sunder.Package.Template.Contracts/**/*"
      ]
    },
    {
      "condition": "(createInPlace)",
      "include": [
        "README.md"
      ]
    }
  ]
}
