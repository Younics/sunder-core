<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Border.panel-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Raised}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="Padding" Value="{DynamicResource Sunder.Padding.Panel}" />
    <Setter Property="BoxShadow" Value="0 18 48 0 #33000000" />
  </Style>

  <Style Selector="Border.workspace-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Workspace}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Large}" />
    <Setter Property="Padding" Value="{DynamicResource Sunder.Padding.Panel}" />
  </Style>

  <Style Selector="Border.card-surface">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="{DynamicResource Sunder.Padding.Card}" />
    <Setter Property="BoxShadow" Value="0 10 30 0 #26000000" />
  </Style>

  <Style Selector="Button.primary-action">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Accent}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.OnAccent}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Accent}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="{DynamicResource Sunder.Padding.ActionButton}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.primary-action:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Info}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Info}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.OnAccent}" />
  </Style>

  <Style Selector="Button.secondary-action">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="{DynamicResource Sunder.Padding.ActionButton}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.secondary-action:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Button.danger-action">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Danger.Soft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Danger}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.OnDanger}" />
  </Style>

  <Style Selector="Button.compact-action">
    <Setter Property="Height" Value="34" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="MinWidth" Value="72" />
  </Style>

  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="{DynamicResource Sunder.FontSize.PageTitle}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="{DynamicResource Sunder.FontSize.SectionTitle}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="TextBlock.caption">
    <Setter Property="FontSize" Value="{DynamicResource Sunder.FontSize.Caption}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Secondary}" />
    <Setter Property="LineHeight" Value="17" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="CaretBrush" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource Sunder.Brush.Selection}" />
    <Setter Property="SelectionForegroundBrush" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="TextBox:focus, TextBox:focus-within, TextBox:focus-visible">
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Focus}" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
  </Style>

  <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Muted}" />
    <Setter Property="Opacity" Value="0.95" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinHeight" Value="36" />
  </Style>

  <Style Selector="ComboBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Strong}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="ComboBox:focus, ComboBox:focus-within, ComboBox:focus-visible">
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Focus}" />
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Popover}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Selected}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="ComboBoxItem:selected:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Selection}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Base}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Sunder.Brush.Border.Subtle}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
    <Setter Property="Padding" Value="6" />
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Sunder.Radius.Small}" />
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Hover}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="{DynamicResource Sunder.Brush.Surface.Selected}" />
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="ListBoxItem:focus-visible, Button:focus-visible, CheckBox:focus-visible">
    <Setter Property="FocusAdorner" Value="{x:Null}" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>

  <Style Selector="Expander">
    <Setter Property="Foreground" Value="{DynamicResource Sunder.Brush.Foreground.Primary}" />
  </Style>
</Styles>
