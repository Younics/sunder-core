<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <CornerRadius x:Key="Sunder.Radius.Small">8</CornerRadius>
  <CornerRadius x:Key="Sunder.Radius.Medium">12</CornerRadius>
  <CornerRadius x:Key="Sunder.Radius.Large">18</CornerRadius>
  <CornerRadius x:Key="Sunder.Radius.Full">999</CornerRadius>

  <x:Double x:Key="Sunder.Spacing.XSmall">4</x:Double>
  <x:Double x:Key="Sunder.Spacing.Small">8</x:Double>
  <x:Double x:Key="Sunder.Spacing.Medium">12</x:Double>
  <x:Double x:Key="Sunder.Spacing.Large">16</x:Double>
  <x:Double x:Key="Sunder.Spacing.XLarge">24</x:Double>

  <Thickness x:Key="Sunder.Padding.Card">14</Thickness>
  <Thickness x:Key="Sunder.Padding.Panel">18</Thickness>
  <Thickness x:Key="Sunder.Padding.ActionButton">16,8</Thickness>

  <x:Double x:Key="Sunder.FontSize.Caption">12</x:Double>
  <x:Double x:Key="Sunder.FontSize.Body">14</x:Double>
  <x:Double x:Key="Sunder.FontSize.SectionTitle">14</x:Double>
  <x:Double x:Key="Sunder.FontSize.PageTitle">24</x:Double>
</ResourceDictionary>
